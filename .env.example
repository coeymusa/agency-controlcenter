# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# --- Auth ---
# Bearer token used by Claude + CLI to call /api/* write endpoints
CONTROL_API_TOKEN="generate-a-long-random-string"
# Cookie password for the dashboard UI
DASHBOARD_PASSWORD="set-a-password"

# --- Public base URL (for open pixel + click redirects in outbound emails) ---
# In prod set to your Vercel domain; locally it's http://localhost:3000
NEXT_PUBLIC_TRACK_BASE="http://localhost:3000"

# --- Gmail OAuth (for reply sync) ---
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
GMAIL_USER="coreymusa1@gmail.com"

# --- Outlook / Microsoft Graph OAuth (for reply sync) ---
OUTLOOK_TENANT="common"
OUTLOOK_CLIENT_ID=""
OUTLOOK_REFRESH_TOKEN=""
OUTLOOK_USER=""
